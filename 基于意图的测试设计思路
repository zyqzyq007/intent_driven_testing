from javalang.tree import MethodInvocation
实现逻辑（核心）
def extract_invoked_methods(method_ast):
    invoked = set()
    for path, node in method_ast:
        if isinstance(node, MethodInvocation):
            invoked.add(node.member)  # method name
    return invoked
